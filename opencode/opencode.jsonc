{
  "plugin": [
    "oh-my-openagent@latest",
    "@tarquinen/opencode-dcp@latest",
    "@nick-vi/opencode-type-inject",
    "opencode-pty",
    "opencode-wakatime",
    "opencode-helicone-session",
    "opencode-scheduler",
    "opencode-supermemory"
  ],
  "instructions": [
    "~/.config/opencode/plugin/shell-strategy/shell_strategy.md",
  ],
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "postgres": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "mcp/postgres",
        "postgresql://postgres:{env:POSTGRES_PASSWORD}@host.docker.internal:5432/{env:POSTGRES_DB}"
      ],
      "enabled": false
    },
    "postgres_rw": {
      "type": "local",
      "command": [
        "node",
        "/Users/psharma/.config/opencode/mcp/postgres-rw/index.js",
        "postgresql://postgres:{env:POSTGRES_PASSWORD}@localhost:5432/{env:POSTGRES_DB}"
      ],
      "enabled": false
    },
    "rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}",
        "X-MCP-Insiders": "true"
      },
      "enabled": true
    },
    "jetbrains": {
      "type": "remote",
      "url": "http://localhost:64342/sse",
      "enabled": false
    },
    "jetbrains-pycharm": {
      "type": "remote",
      "url": "http://localhost:64343/sse",
      "enabled": false
    },
    "aifr-preprod": {
      "type": "remote",
      "url": "https://aifr.saas-preprod.beescloud.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:AIFR_PREPROD_KEY}"
      },
      "enabled": false
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "obsidian-mcp-server"
      ],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}",
        "OBSIDIAN_BASE_URL": "http://127.0.0.1:27123",
        "OBSIDIAN_VERIFY_SSL": "false",
        "OBSIDIAN_ENABLE_CACHE": "true"
      },
      "enabled": true
    },
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        // "callbackPort": 3118
      },
      "enabled": false
    },
    "codegraphcontext": {
      "type": "local",
      "command": [
        "/Users/psharma/dotfiles/codegraphcontext/start-mcp.sh"
      ],
      "environment": {
        "DEFAULT_DATABASE": "neo4j",
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "{env:NEO4J_PASSWORD}"
      },
      "enabled": true
    },
    "superset": {
      "type": "remote",
      "url": "https://api.superset.sh/api/agent/mcp",
      "oauth": {}
    },
    "unify": {
      "type": "remote",
      "url": "https://mcp.cloudbees.io/v1/mcp",
      "oauth": {
        "clientId": "public-mcp-client",
        "redirectUri": "http://localhost:19876/mcp/oauth/callback"
      },
      "enabled": true
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "cb-bedrock"
      },
    }
  }
}
